<?xml version="1.0" encoding="utf-8"?>
<!--
   备份规则配置 — 配合 Android Auto Backup 实现卸载重装后自动恢复数据
   详见 https://developer.android.com/guide/topics/data/autobackup
   注意：此文件在 API 31+ 设备上配合 data_extraction_rules.xml 使用
-->
<full-backup-content>
   <!-- 备份 SecureStorage 的 prefs（Token、Username、Profile 缓存等） -->
   <include domain="sharedpref" path="app_auth_prefs_v2.xml" />

   <!-- 备份 DeviceIdManager 的 prefs（设备 ID） -->
   <include domain="sharedpref" path="device_id_prefs.xml" />
</full-backup-content>