<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/clannad_dashboard">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

        <!-- 密钥交换算法卡片 -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/cipher_key_exchange" android:textSize="18sp" android:textStyle="bold" />

                <TextView android:id="@+id/tv_key_exchange" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:padding="12dp" android:background="@color/clannad_card" android:textSize="14sp" android:textColor="@color/profile_text_dark" android:lineSpacingExtra="4dp" android:text="加载中..." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 数据加密算法卡片 -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/cipher_data_encryption" android:textSize="18sp" android:textStyle="bold" />

                <TextView android:id="@+id/tv_data_encryption" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:padding="12dp" android:background="@color/clannad_card" android:textSize="14sp" android:textColor="@color/profile_text_dark" android:lineSpacingExtra="4dp" android:text="加载中..." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 设备首选算法 -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/card_device_pref" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:visibility="gone" app:cardCornerRadius="12dp" app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/cipher_device_pref" android:textSize="18sp" android:textStyle="bold" />

                <TextView android:id="@+id/tv_device_cipher_pref" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textSize="16sp" android:textColor="@color/profile_text_dark" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 可用算法列表 -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="2dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/cipher_available" android:textSize="18sp" android:textStyle="bold" />

                <LinearLayout android:id="@+id/layout_available_algorithms" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>