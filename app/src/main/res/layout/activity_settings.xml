<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/clannad_dashboard">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <!-- 顶部 Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar" android:layout_width="match_parent" android:layout_height="?attr/actionBarSize" android:background="@color/clannad_navigator" app:title="@string/action_settings" app:navigationIcon="@android:drawable/ic_menu_revert" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

            <!-- 连接状态卡片 -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:id="@+id/iv_connection_indicator" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/presence_offline" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/connection_status" android:textSize="12sp" android:textColor="@android:color/darker_gray" />

                        <TextView android:id="@+id/tv_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/status_disconnected" android:textSize="16sp" android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 设备信息卡片 -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/device_info" android:textSize="16sp" android:textStyle="bold" />

                    <TextView android:id="@+id/tv_username" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="用户: -" />

                    <TextView android:id="@+id/tv_device_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="设备 ID: -" android:textSize="12sp" />

                    <TextView android:id="@+id/tv_cipher" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="加密算法: -" android:textSize="12sp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cipher_pref_label" android:textSize="14sp" />

                        <Spinner android:id="@+id/spinner_cipher" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:entries="@array/cipher_options" />

                    </LinearLayout>

                    <TextView android:id="@+id/tv_last_result" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/result_empty" android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 操作按钮 -->
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_toggle_connection" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:text="@string/btn_connect" />

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_unbind" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:text="@string/btn_unbind" app:backgroundTint="@android:color/holo_orange_dark" />

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_exit" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:text="@string/btn_exit" app:backgroundTint="@android:color/holo_red_dark" />

            <!-- ============ App Lock 卡片 ============ -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lock_section" android:textSize="16sp" android:textStyle="bold" />

                    <!-- 应用锁开关 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lock_enable" android:textSize="14sp" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lock_enable_summary" android:textSize="12sp" android:textColor="@android:color/darker_gray" />

                        </LinearLayout>

                        <TextView android:id="@+id/tv_lock_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:textSize="12sp" android:textColor="@android:color/darker_gray" />

                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_lock" android:layout_width="wrap_content" android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- 锁定详情选项组（仅在锁开启时可见） -->
                    <LinearLayout android:id="@+id/lock_options_group" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@android:color/darker_gray" />

                        <!-- 修改/设置 PIN -->
                        <com.google.android.material.button.MaterialButton android:id="@+id/btn_change_pin" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" style="@style/Widget.Material3.Button.OutlinedButton" />

                        <!-- 指纹解锁 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">

                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lock_biometric" android:textSize="14sp" />

                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lock_biometric_summary" android:textSize="12sp" android:textColor="@android:color/darker_gray" />

                            </LinearLayout>

                            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_biometric" android:layout_width="wrap_content" android:layout_height="wrap_content" />

                        </LinearLayout>

                        <!-- 超时时间 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/lock_timeout" android:textSize="14sp" />

                            <Spinner android:id="@+id/spinner_timeout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:entries="@array/lock_timeout_options" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============ 保活设置卡片 ============ -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keepalive_section" android:textSize="16sp" android:textStyle="bold" />

                    <!-- 保活模式切换 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keepalive_mode_label" android:textSize="14sp" />

                        <Spinner android:id="@+id/spinner_keepalive_mode" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@android:color/darker_gray" />

                    <!-- 定时唤醒 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keepalive_periodic_wakeup" android:textSize="14sp" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keepalive_periodic_wakeup_summary" android:textSize="12sp" android:textColor="@android:color/darker_gray" />

                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_periodic_wakeup" android:layout_width="wrap_content" android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- 唤醒间隔（仅在定时唤醒启用时可见） -->
                    <LinearLayout android:id="@+id/layout_wakeup_interval" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal" android:visibility="gone">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keepalive_wakeup_interval" android:textSize="14sp" />

                        <Spinner android:id="@+id/spinner_wakeup_interval" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" />

                    </LinearLayout>

                    <!-- MIUI 优化引导（仅在 MIUI 系统显示） -->
                    <LinearLayout android:id="@+id/layout_miui_optimization" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:visibility="gone">

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginBottom="12dp" android:background="@android:color/darker_gray" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/keepalive_miui_title" android:textSize="14sp" android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton android:id="@+id/btn_miui_auto_start" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/keepalive_miui_auto_start" style="@style/Widget.Material3.Button.OutlinedButton" />

                        <com.google.android.material.button.MaterialButton android:id="@+id/btn_miui_battery" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/keepalive_miui_battery" style="@style/Widget.Material3.Button.OutlinedButton" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
