<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 前台服务权限（Android 13+ 需显式声明） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_REMOTE_MESSAGING" />

    <!-- 通知权限（Android 13+） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application android:name=".MyAuthenticatorApp" android:allowBackup="true" android:dataExtractionRules="@xml/data_extraction_rules" android:fullBackupContent="@xml/backup_rules" android:icon="@mipmap/ic_launcher" android:label="@string/app_name" android:roundIcon="@mipmap/ic_launcher_round" android:supportsRtl="true" android:theme="@style/Theme.MyAuthenticator" android:usesCleartextTraffic="true" tools:targetApi="33">

        <!-- 登录 Activity（入口） -->
        <activity android:name=".ui.login.LoginActivity" android:exported="true" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 绑定 Activity -->
        <activity android:name=".ui.bind.BindActivity" android:exported="false" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize" />

        <!-- 主 Activity -->
        <activity android:name=".ui.main.MainActivity" android:exported="false" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize" />

        <!-- 设置 Activity -->
        <activity android:name=".ui.settings.SettingsActivity" android:exported="false" android:theme="@style/Theme.MyAuthenticator" />

        <!-- WebSocket 前台服务 -->
        <service android:name=".service.WebSocketService" android:foregroundServiceType="remoteMessaging" android:exported="false" />

    </application>

</manifest>
