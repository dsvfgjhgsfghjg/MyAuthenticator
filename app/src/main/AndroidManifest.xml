<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 前台服务权限（Android 13+ 需显式声明） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_REMOTE_MESSAGING" />

    <!-- 通知权限（Android 13+） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 指纹/生物识别权限 -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- 保活相关权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- AccountManager 权限（自家 authenticator 不需要用户弹窗，只在清单声明即可） -->
    <uses-permission android:name="android.permission.AUTHENTICATE_ACCOUNTS" />
    <uses-permission android:name="android.permission.MANAGE_ACCOUNTS" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />

    <application android:name=".MyAuthenticatorApp" android:allowBackup="true" android:dataExtractionRules="@xml/data_extraction_rules" android:fullBackupContent="@xml/backup_rules" android:icon="@mipmap/ic_launcher" android:label="@string/app_name" android:roundIcon="@mipmap/ic_launcher_round" android:supportsRtl="true" android:theme="@style/Theme.MyAuthenticator" android:usesCleartextTraffic="true" tools:targetApi="33">

        <!-- 解锁 Activity（Launcher 入口） — 先检查应用锁，通过后跳转 MainActivity -->
        <activity android:name=".ui.lock.UnlockActivity" android:exported="true" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize" android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 主 Activity — 始终显示主视图，登录后自动重连 -->
        <activity android:name=".ui.main.MainActivity" android:exported="true" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize" />

        <!-- 登录 Activity（用户点击"登录"时打开） -->
        <activity android:name=".ui.login.LoginActivity" android:exported="false" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize" />

        <!-- 绑定 Activity -->
        <activity android:name=".ui.bind.BindActivity" android:exported="false" android:theme="@style/Theme.MyAuthenticator" android:windowSoftInputMode="adjustResize" />

        <!-- 设置 Activity -->
        <activity android:name=".ui.settings.SettingsActivity" android:exported="false" android:theme="@style/Theme.MyAuthenticator" />

        <!-- WebSocket 前台服务 -->
        <service android:name=".service.WebSocketService" android:foregroundServiceType="remoteMessaging" android:exported="false" />

        <!-- 守护进程服务（独立 :guard 进程） -->
        <service android:name=".keepalive.DaemonGuardService" android:process=":guard" android:exported="false" android:enabled="true" />

        <!-- 开机自启广播接收器 -->
        <receiver android:name=".keepalive.BootReceiver" android:exported="false" android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 定时唤醒广播接收器 -->
        <receiver android:name=".keepalive.PeriodicWakeupReceiver" android:exported="false" android:enabled="true" />

        <!-- AccountAuthenticator（系统级持久化账号，卸载重装后数据仍保留） -->
        <service android:name=".authenticator.AuthenticatorService" android:exported="false">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data android:name="android.accounts.AccountAuthenticator" android:resource="@xml/authenticator" />
        </service>

    </application>

</manifest>
